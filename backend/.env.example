# App
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://musictailor:musictailor@localhost:5432/musictailor

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Frontend URL (used for OAuth post-auth redirect)
FRONTEND_URL=http://localhost:5173

# Spotify OAuth — register an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8000/auth/spotify/callback to the app's Redirect URIs.
# Note: Spotify enforces 127.0.0.1 (not localhost) for loopback redirects on new apps.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/spotify/callback

# Last.fm — request an API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Genius — get an access token at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# Session secret — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-only-change-me
